{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medley.local/schemas/onboard-catalog.json",
  "title": "Onboard Catalog",
  "description": "Schema for .claude/skills/onboard/catalog.json. Validated in CI by check-jsonschema (Phase 2 prereq). Per-phase entry shapes vary because each Phase 3+ check script has different data needs (git-config keys vs shell sentinels vs chrome host paths).",
  "type": "object",
  "additionalProperties": false,
  "required": ["_schema_version", "_doc", "phases"],
  "properties": {
    "_schema_version": {
      "type": "string",
      "const": "1",
      "description": "Bumped only on breaking schema changes. Loaders verify and fail on mismatch."
    },
    "_doc": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable scope statement. Documents which phases consume the catalog and why others stay imperative (D9)."
    },
    "phases": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_config",
        "shell_profile",
        "project_setup",
        "api_tokens",
        "mcp_servers",
        "plugins",
        "optional_features"
      ],
      "properties": {
        "git_config": {
          "type": "array",
          "items": { "$ref": "#/$defs/git_config_entry" }
        },
        "shell_profile": {
          "type": "array",
          "items": { "$ref": "#/$defs/shell_profile_entry" }
        },
        "project_setup": {
          "type": "array",
          "items": { "$ref": "#/$defs/project_setup_entry" }
        },
        "api_tokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/dynamic_metadata_entry" }
        },
        "mcp_servers": {
          "type": "array",
          "items": { "$ref": "#/$defs/dynamic_metadata_entry" }
        },
        "plugins": {
          "type": "array",
          "items": { "$ref": "#/$defs/dynamic_metadata_entry" }
        },
        "optional_features": {
          "type": "array",
          "items": { "$ref": "#/$defs/optional_feature_entry" }
        }
      }
    }
  },
  "$defs": {
    "common_fields": {
      "type": "object",
      "required": ["id", "tier", "os"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9._-]*$",
          "description": "Stable identifier within the phase. May include dots (git config keys) and dashes."
        },
        "_comment": {
          "type": "string",
          "description": "Optional but encouraged. Per D2: documents WHY this row exists. Surfaces in /onboard update review."
        },
        "tier": {
          "type": "string",
          "enum": ["required", "recommended", "optional"]
        },
        "os": { "$ref": "#/$defs/os_field" }
      }
    },
    "os_field": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["all", "windows", "macos", "linux"]
        },
        {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["windows", "macos", "linux"]
          }
        }
      ]
    },
    "git_config_entry": {
      "allOf": [
        { "$ref": "#/$defs/common_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["expected"],
          "properties": {
            "id": true,
            "_comment": true,
            "tier": true,
            "os": true,
            "expected": {
              "type": "string",
              "minLength": 1,
              "description": "Exact value to match against `git config --local <id>` (with --global fallback per check-git-config.sh)."
            }
          }
        }
      ]
    },
    "shell_profile_entry": {
      "allOf": [
        { "$ref": "#/$defs/common_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "sentinel"],
          "properties": {
            "id": true,
            "_comment": true,
            "tier": true,
            "os": true,
            "label": {
              "type": "string",
              "description": "Output label per row in check-bash-profile.sh."
            },
            "sentinel": {
              "type": "string",
              "description": "Literal string grep'd for in target rc file. Sentinels include em-dash (—) and carry the 'medley /onboard' suffix on managed blocks except fnm."
            },
            "scaffold_var": {
              "type": "string",
              "pattern": "^EXPECTED_[A-Z_]+$",
              "description": "Name of the expected-content variable in scaffolds/bash-profile-blocks.sh — paired with audit-bash-profile.sh content-drift checks."
            }
          }
        }
      ]
    },
    "project_setup_entry": {
      "allOf": [
        { "$ref": "#/$defs/common_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "detect_method", "fix_hint"],
          "properties": {
            "id": true,
            "_comment": true,
            "tier": true,
            "os": true,
            "label": { "type": "string" },
            "detect_method": {
              "type": "string",
              "enum": [
                "env_var",
                "git_hook",
                "node_module_bin",
                "dotnet_assets",
                "bootstrap_check",
                "bootstrap_rows"
              ]
            },
            "detect_arg": {
              "type": "string",
              "description": "Argument for the detection method (e.g., hook name 'pre-commit', binary name 'markdownlint-cli2'). Optional for methods that take none (dotnet_assets, bootstrap_check)."
            },
            "fix_hint": {
              "type": "string",
              "description": "Command suggested in the FAIL row's detail column."
            }
          }
        }
      ]
    },
    "dynamic_metadata_entry": {
      "allOf": [
        { "$ref": "#/$defs/common_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "detect_script"],
          "properties": {
            "id": {
              "type": "string",
              "const": "_dynamic",
              "description": "Sentinel id signaling this phase is data-driven from `source`, not from catalog rows. /onboard update reads `source` to correlate drift."
            },
            "_comment": true,
            "tier": true,
            "os": true,
            "source": {
              "type": "string",
              "description": "Repo-relative path to the source-of-truth file (e.g., .mcp.json, .claude/settings.json) the phase derives state from."
            },
            "detect_script": {
              "type": "string",
              "pattern": "^scripts/check-[a-z-]+\\.sh$",
              "description": "Repo-relative path to the check-*.sh that owns this phase."
            },
            "tracked": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 },
              "description": "Enumerated names known to /onboard update at last apply. For mcp_servers: top-level keys in .mcp.json mcpServers. For api_tokens: ${VAR} references resolved from .mcp.json (env/args/url/headers). For plugins: enabledPlugins keys in .claude/settings.json. Drift = source enumeration differs from this array. /onboard update --apply appends new items; never deletes."
            }
          }
        }
      ]
    },
    "optional_feature_entry": {
      "allOf": [
        { "$ref": "#/$defs/common_fields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["host_id", "locations"],
          "properties": {
            "id": true,
            "_comment": true,
            "tier": true,
            "os": true,
            "host_id": {
              "type": "string",
              "description": "Native messaging host identifier registered for the optional feature (e.g., com.anthropic.claude_code_browser_extension)."
            },
            "locations": {
              "type": "object",
              "additionalProperties": false,
              "minProperties": 1,
              "patternProperties": {
                "^(windows|macos|linux)-(chrome|edge|firefox|safari)$": {
                  "$ref": "#/$defs/optional_feature_location"
                }
              }
            }
          }
        }
      ]
    },
    "optional_feature_location": {
      "type": "object",
      "oneOf": [
        {
          "additionalProperties": false,
          "required": ["type", "key_prefix"],
          "properties": {
            "type": { "const": "registry" },
            "key_prefix": {
              "type": "string",
              "description": "Windows registry key prefix; host_id is appended at detection time."
            }
          }
        },
        {
          "additionalProperties": false,
          "required": ["type", "dir"],
          "properties": {
            "type": { "const": "file" },
            "dir": {
              "type": "string",
              "description": "Directory containing the manifest file. <host_id>.json is appended at detection time."
            }
          }
        }
      ]
    }
  }
}
