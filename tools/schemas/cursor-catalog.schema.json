{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medley.local/schemas/cursor-catalog.json",
  "title": "Cursor catalog cache",
  "type": "object",
  "additionalProperties": false,
  "required": ["fetchedAt", "models"],
  "properties": {
    "fetchedAt": { "type": "string" },
    "pricingIndexUrl": { "type": "string", "format": "uri" },
    "pricingContentHash": { "type": "string" },
    "pools": { "type": "object" },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "docUrl": { "type": "string" },
          "pool": { "type": "string" },
          "defaultSlug": { "type": "string" },
          "cliSlugs": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
