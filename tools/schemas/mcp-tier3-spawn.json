{
  "command": "fnm",
  "forbiddenCommands": ["bash", "node", "npx", "sh"],
  "fnmExecPrefix": [
    "exec",
    "--version-file-strategy=recursive",
    "--using=.nvmrc",
    "--",
    "node",
    "tools/mcp-launcher/launcher.js"
  ],
  "launcherPath": "tools/mcp-launcher/launcher.js",
  "requiredEnv": {
    "MCP_LAUNCHER_FNM_ACTIVE": "1"
  }
}
