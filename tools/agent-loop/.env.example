# Copy to .env (gitignored):  cp .env.example .env
#
# Precedence: OS environment wins — values here apply only when the var is unset
# or empty in the parent process.
#
# User API Key: Cursor → Settings → Integrations → User API Keys (crsr_… format).
# Admin API keys do not work with cursor-agent.

CURSOR_API_KEY=

# Claude Code subscription OAuth — from `claude setup-token` on host; per-developer; never commit.
# Do not set ANTHROPIC_API_KEY when using the Claude pool — metered key overrides subscription OAuth.
CLAUDE_CODE_OAUTH_TOKEN=
