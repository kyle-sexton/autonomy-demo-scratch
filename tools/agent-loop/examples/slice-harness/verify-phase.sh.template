#!/usr/bin/env bash
# Host verify: PLAN Phase {{PHASE}} Sanity Check

set -euo pipefail
source "$(dirname "$0")/verify-common.sh"

PHASE={{PHASE}}
FAILED=0

run() { "$@" || FAILED=$((FAILED + 1)); }

echo "=== verify-phase-{{PHASE}} ==="

run assert_not_blocked "$PHASE"
run assert_phase_done_marker "$PHASE"
run assert_plan_phase_done "$PHASE"

# <fill: PLAN sanity check commands — e.g. assert_dir, assert_grep_zero, npm test>

if [[ $FAILED -eq 0 ]]; then
  echo "=== verify-phase-{{PHASE}}: ALL PASS ==="
  exit 0
fi
echo "=== verify-phase-{{PHASE}}: $FAILED FAILURE(S) ===" >&2
exit 1
